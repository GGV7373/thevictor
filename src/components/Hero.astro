---

<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-layout">
    <div class="hero-text-block">
      <p class="hero-kicker">Developer &amp; Creator</p>
      <h1 class="hero-title">Building things that matter</h1>
      <p class="hero-tagline">(or not)</p>
      <p class="hero-desc">
        I build practical websites, automation tools, and AI-powered projects with a
        strong focus on real-world usefulness, clean delivery, and learning by doing.
      </p>
    </div>

    <div class="hero-photo-block">
      <img src="/me.webp" alt="Portrait of Victor Husefest" loading="lazy" class="hero-portrait-img" />
      <span class="hero-name-label">Victor Husefest</span>
    </div>

    <div class="hero-actions">
      <a href="/contact" class="btn">Get in Touch</a>
      <a href="/projects" class="btn btn-outline">View Work</a>
    </div>
  </div>
</section>
