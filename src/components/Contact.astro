---
interface Props {
  detailed?: boolean;
}

const { detailed = false } = Astro.props;
---

<section id="contact">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">Contact</p>
      <h2 class="section-title">{detailed ? 'Get in touch' : "Let's Talk"}</h2>
    </div>

    <div class="contact-intro">
      <div class="contact-description">
        <p>
          I'm passionate about building meaningful technology solutions and welcome
          opportunities to connect with like-minded people. Whether you're interested
          in collaborating on a project, discussing potential opportunities, or
          exploring ways we can work together, I'd be glad to hear from you.
        </p>
      </div>
    </div>

    {detailed ? (
      <>
        <div class="contact-methods">
          <h3 class="contact-subtitle">I'm interested in:</h3>
          <div class="interests-grid">
            <div class="interest-item">Freelance &amp; Contract Work</div>
            <div class="interest-item">Full-time Opportunities</div>
            <div class="interest-item">Collaboration Projects</div>
            <div class="interest-item">Tech Discussions &amp; Ideas</div>
            <div class="interest-item">General Inquiries</div>
            <div class="interest-item">Consulting</div>
          </div>
        </div>

        <div class="contact-cta-buttons">
          <a href="mailto:thevictor-con@outlook.com" class="contact-cta-btn">Send me an email</a>
          <div class="contact-cta-row">
            <a href="https://github.com/GGV7373" class="contact-cta-btn" target="_blank" rel="noopener noreferrer">My GitHub</a>
            <a href="https://www.linkedin.com/in/victor-husefest-6372843aa/" class="contact-cta-btn" target="_blank" rel="noopener noreferrer">My LinkedIn</a>
          </div>
        </div>

        <div class="response-info">
          <h3 class="contact-subtitle">Response time:</h3>
          <p class="response-text">
            I aim to respond to all inquiries within 24 to 48 hours. If you don't
            receive a response, feel free to follow up, as messages occasionally go
            undelivered. For time-sensitive matters, LinkedIn may be the most
            reliable way to reach me.
          </p>
        </div>

        <div class="cta-section">
          <p class="cta-text">
            I'm open to freelance work and collaborations. If you have an
            interesting project or opportunity in mind, feel free to reach out.
          </p>
        </div>
      </>
    ) : (
      <div class="contact-actions">
        <a href="mailto:thevictor-con@outlook.com" class="btn">Send an Email</a>
        <a href="https://github.com/GGV7373" class="btn btn-outline" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/victor-husefest-6372843aa/" class="btn btn-outline" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    )}
  </div>
</section>
