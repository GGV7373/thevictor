---
---

<section id="projects">
  <div class="container">
    <div class="projects-header">
      <h2 class="section-title">Projects</h2>
      <a href="/projects" class="btn btn-outline">Search</a>
    </div>

    <div class="main-project-section">
      <h3 class="project-section-title">Main project</h3>
      <div class="main-project-card">
        <h4 class="project-title">Personal Portfolio</h4>
        <p class="project-desc">A personal portfolio website built with HTML, CSS, and JavaScript to showcase my work and skills.</p>
        <a href="https://thevictor.net" class="project-link" target="_blank" rel="noopener noreferrer">View Website &rarr;</a>
      </div>
    </div>

    <div class="side-projects-section">
      <h3 class="project-section-title">Side projects</h3>
      <p class="side-projects-desc">
        Here are some other projects
        that I like. It should be
        simple to swap them out with
        new or better projects.
      </p>
      <div class="side-projects-grid">
        <article class="project-card">
          <h4 class="project-title">Bibel Ollama</h4>
          <p class="project-desc">This project is a Bible study tool that leverages AI to provide insights and interpretations.</p>
          <a href="https://github.com/GGV7373/Bible-Ollama" class="project-link" target="_blank" rel="noopener noreferrer">View on GitHub &rarr;</a>
        </article>

        <article class="project-card">
          <h4 class="project-title">aiawards.no</h4>
          <p class="project-desc">The official website for the Tangen VGS AI Awards, showcasing nominees, winners, and event details.</p>
          <a href="https://www.aiawards.no" class="project-link" target="_blank" rel="noopener noreferrer">View Website &rarr;</a>
        </article>
      </div>
    </div>

    <div class="projects-cta">
      <a href="/projects" class="btn btn-outline">
        Se more <span class="arrow">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
.projects-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
}

.main-project-section {
  margin-bottom: 3rem;
}

.project-section-title {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 1.5rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--color-grid);
}

.main-project-card {
  background: var(--color-surface);
  border: 2px solid var(--color-grid);
  border-radius: 0px;
  padding: 2rem;
  text-align: center;
  transition: border-color var(--transition), transform var(--transition);
}

.main-project-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-2px);
}

.side-projects-section {
  margin-bottom: 3rem;
}

.side-projects-desc {
  color: var(--color-text-secondary);
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
}

.side-projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

@media (max-width: 600px) {
  .projects-header {
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .main-project-card {
    padding: 1.5rem;
  }

  .side-projects-grid {
    grid-template-columns: 1fr;
  }
}
</style>
