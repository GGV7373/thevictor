---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import logoUrl from '../../thevictor.net.svg';

interface Props {
  title: string;
  pageClass?: string;
}

const { title, pageClass = '' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={logoUrl} type="image/svg+xml" />
    <title>{title} | the-victor</title>
  </head>
  <body class={pageClass}>
    <Navigation />
    <slot />
    <Footer />
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
  }
</style>