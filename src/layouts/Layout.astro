---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/index.css';

interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}

const {
  title,
  description = 'Portfolio of Victor Husefest, a software developer and IT consultant building practical tools, web projects, and automation-focused solutions.',
  pageClass = '',
} = Astro.props;

const canonicalUrl = Astro.url;
const socialImage = new URL('/me.webp', Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/logo.webp" type="image/webp" />
    <title>{title} | thevictor.net</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="thevictor.net" />
    <meta property="og:title" content={`${title} | thevictor.net`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | thevictor.net`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
  </head>
  <body class={pageClass}>
    <Navigation />
    <slot />
    <Footer />
    <script>
      import '../scripts/scroll-reveal.ts';
    </script>
  </body>
</html>
