---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import '../styles/home.css';
---

<Layout title="Home">
  <Hero />
  
  <About />

  <section id="home-nav">
    <div class="container">
      <div class="home-nav-grid">

        <a href="/qualifications" class="home-nav-card">
          <span class="home-nav-eyebrow">Tech competence</span>
          <h2 class="home-nav-title">Qualifications</h2>
          <p class="home-nav-desc">
            Python, JavaScript, HTML &amp; CSS, Cloudflare, TCP/IP, Linux, Docker,
            AI integration and more.
          </p>
          <span class="home-nav-arrow">&rarr;</span>
        </a>

        <a href="/projects" class="home-nav-card">
          <span class="home-nav-eyebrow">Selected work</span>
          <h2 class="home-nav-title">Projects</h2>
          <p class="home-nav-desc">
            Bibel Ollama, personal portfolio, aiawards.no, web scrapers and more —
            see everything I've built.
          </p>
          <span class="home-nav-arrow">&rarr;</span>
        </a>

        <a href="/contact" class="home-nav-card">
          <span class="home-nav-eyebrow">Get in touch</span>
          <h2 class="home-nav-title">Contact</h2>
          <p class="home-nav-desc">
            Open to collaboration, freelance work, and new opportunities.
            I'm always happy to hear from you.
          </p>
          <span class="home-nav-arrow">&rarr;</span>
        </a>

      </div>
    </div>
  </section>
</Layout>

<script>
  import '../scripts/smooth-scroll.ts';
</script>
