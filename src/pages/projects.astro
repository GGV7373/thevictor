---
import { readFile } from 'node:fs/promises';
import { resolve } from 'node:path';
import Layout from '../layouts/Layout.astro';

interface Project {
  title: string;
  desc: string;
  tags?: string[];
  link?: string;
  linkText: string;
}

const projectsFile = resolve(process.cwd(), 'public', 'data', 'projects.json');
const { projects } = JSON.parse(await readFile(projectsFile, 'utf-8')) as { projects: Project[] };
---

<Layout
  title="Projects"
  description="Browse projects by Victor Husefest, including AI tools, automation scripts, portfolio work, and team collaborations."
  pageClass="projects-page"
>
  <section id="projects" class="projects-page-shell">
    <div class="container">
      <div class="section-heading projects-header">
        <div>
          <p class="section-eyebrow">Archive</p>
          <h2 class="section-title">Projects</h2>
        </div>
        <div class="projects-search">
          <input
            type="text"
            class="projects-search-input"
            placeholder="Search"
            id="projects-search-input"
            aria-label="Search projects"
          />
        </div>
      </div>

      <p class="section-text page-intro">
        Here are some of the projects I've worked on. Use the tags to get a quick overview of the tools,
        languages, and collaboration patterns involved.
      </p>

      <div class="projects-content-area">
        <div id="main-project-container"></div>

        <div id="side-projects-container">
          <h3 class="side-projects-heading">Side projects</h3>
          <div class="projects-grid" data-projects-grid></div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ projects }}>
  window.__PROJECTS_DATA__ = projects;
</script>

<script>
  import '../scripts/projects.ts';
</script>
